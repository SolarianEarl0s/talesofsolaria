<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tales of Solaria | A Six-Act Fantasy Saga</title>
  <meta name="description" content="A six-act fantasy saga brought to life through cinematic storytelling, living lore, and digital worldbuilding.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background-color: #0d0b1a;
      color: #e8e0cc;
      font-family: 'Raleway', 'Helvetica Neue', sans-serif;
      font-weight: 400;
      line-height: 1.7;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    :root {
      --color-bg: #0d0b1a;
      --color-surface: #13102b;
      --color-surface-2: #1a1535;
      --color-surface-offset: #221d40;
      --color-border: rgba(201,168,76,0.15);
      --color-gold: #c9a84c;
      --color-gold-hover: #e2c06a;
      --color-gold-dim: rgba(201,168,76,0.6);
      --color-text: #e8e0cc;
      --color-text-muted: #a09880;
      --color-text-faint: #5a5245;
      --font-display: 'Cinzel', 'Georgia', serif;
      --font-body: 'Raleway', 'Helvetica Neue', sans-serif;
      --space-2: 0.5rem; --space-3: 0.75rem; --space-4: 1rem;
      --space-6: 1.5rem; --space-8: 2rem; --space-12: 3rem;
      --space-16: 4rem; --space-20: 5rem;
    }

    .skip-link {
      position: absolute; top: -100px; left: var(--space-4);
      background: var(--color-gold); color: #0d0b1a;
      padding: var(--space-2) var(--space-4);
      font-family: var(--font-display); font-size: 0.8rem;
      z-index: 9999; border-radius: 0 0 4px 4px; transition: top 0.2s;
    }
    .skip-link:focus { top: 0; }

    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

    #starfield-canvas {
      position: fixed; top: 0; left: 0;
      width: 100%; height: 100%;
      z-index: 0; pointer-events: none;
    }

    /* ===== NAVIGATION ===== */
    .nav {
      position: fixed; top: 0; left: 0; right: 0;
      display: flex; align-items: center; justify-content: space-between;
      padding: var(--space-4) var(--space-8);
      background: rgba(13,11,26,0.92); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(201,168,76,0.2); z-index: 1000;
    }
    .nav-logo { font-family: var(--font-display); font-size: 1.1rem; font-weight: 700; color: var(--color-gold); letter-spacing: 0.1em; }
    .nav-links { display: flex; align-items: center; gap: var(--space-8); list-style: none; }
    .nav-links a { font-family: var(--font-display); font-size: 0.72rem; letter-spacing: 0.1em; color: var(--color-text-muted); transition: color 0.2s; text-transform: uppercase; }
    .nav-links a:hover { color: var(--color-gold); }
    .nav-links .nav-special { color: var(--color-gold); }
    .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: var(--space-2); }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--color-gold); border-radius: 2px; transition: all 0.3s; }
    .mobile-menu { display: none; position: fixed; top: 64px; left: 0; right: 0; background: rgba(13,11,26,0.98); border-bottom: 1px solid var(--color-border); padding: var(--space-6) var(--space-8); z-index: 999; }
    .mobile-menu.open { display: block; }
    .mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-4); }
    .mobile-menu a { font-family: var(--font-display); font-size: 0.9rem; letter-spacing: 0.1em; color: var(--color-text-muted); text-transform: uppercase; }
    .mobile-menu a:hover { color: var(--color-gold); }

    /* ===== SECTION LABELS ===== */
    .section-label { font-family: var(--font-display); font-size: clamp(1.2rem, 2.5vw, 1.6rem); letter-spacing: 0.15em; color: var(--color-gold); text-align: center; text-transform: uppercase; display: flex; align-items: center; justify-content: center; gap: var(--space-4); }
    .section-label::before, .section-label::after { content: ''; flex: 1; max-width: 80px; height: 1px; background: var(--color-border); }
    .section-sub { font-family: var(--font-body); font-size: 0.9rem; color: var(--color-text-muted); text-align: center; margin-top: var(--space-2); }

    /* ===== BUTTONS ===== */
    .btn-primary { display: inline-flex; align-items: center; gap: var(--space-2); background: var(--color-gold); color: #0d0b1a; font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.75rem var(--space-6); border: 2px solid var(--color-gold); cursor: pointer; transition: background 0.2s, color 0.2s; min-height: 44px; }
    .btn-primary:hover { background: var(--color-gold-hover); border-color: var(--color-gold-hover); }
    .btn-outline { display: inline-flex; align-items: center; gap: var(--space-2); background: transparent; color: var(--color-gold); font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.75rem var(--space-6); border: 2px solid var(--color-gold); cursor: pointer; transition: background 0.2s, color 0.2s; min-height: 44px; }
    .btn-outline:hover { background: rgba(201,168,76,0.1); }

    /* ===== HERO ===== */
    .hero { position: relative; min-height: 100vh; display: flex; align-items: center; padding: 120px var(--space-8) var(--space-20); overflow: hidden; z-index: 1; }
    .hero-glow { position: absolute; top: 0; left: 0; width: 60%; height: 100%; background: radial-gradient(ellipse at 30% 50%, rgba(120,80,200,0.18) 0%, transparent 65%); pointer-events: none; }
    .hero-content { position: relative; z-index: 2; max-width: 560px; }
    .hero-eyebrow { font-family: var(--font-display); font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 700; color: var(--color-gold); letter-spacing: 0.2em; text-transform: uppercase; line-height: 1; }
    .hero-title { font-family: var(--font-display); font-size: clamp(4rem, 10vw, 8rem); font-weight: 900; color: var(--color-gold); letter-spacing: 0.05em; text-transform: uppercase; line-height: 0.9; margin-bottom: var(--space-6); }
    .hero-subtitle { font-size: 1rem; color: var(--color-text-muted); font-weight: 300; max-width: 420px; margin-bottom: var(--space-8); line-height: 1.8; }
    .hero-ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }
    .hero-art { position: absolute; right: 0; top: 0; bottom: 0; width: 55%; z-index: 1; background: linear-gradient(to right, #0d0b1a 5%, transparent 35%); }
    .hero-art img { width: 100%; height: 100%; object-fit: cover; object-position: top center; opacity: 0.75; }
    .hero-art-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #1a1535 0%, #0d0b1a 100%); display: flex; align-items: center; justify-content: center; color: var(--color-text-faint); font-family: var(--font-display); font-size: 0.75rem; letter-spacing: 0.1em; text-align: center; }

    /* ===== CHRONICLES ===== */
    .chronicles { position: relative; z-index: 1; padding: var(--space-20) var(--space-8); background: linear-gradient(to bottom, transparent, rgba(19,16,43,0.5) 20%, rgba(19,16,43,0.5) 80%, transparent); }
    .section-header { margin-bottom: var(--space-12); }
    .acts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: var(--space-6); max-width: 1100px; margin: 0 auto; }
    .act-card { background: var(--color-surface); border: 1px solid var(--color-border); overflow: hidden; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .act-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(201,168,76,0.15); }
    .act-thumbnail { position: relative; width: 100%; aspect-ratio: 16/9; overflow: hidden; background: var(--color-surface-2); }
    .act-thumbnail img { width: 100%; height: 100%; object-fit: cover; }
    .act-thumb-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #1a1535, #0d0b1a); display: flex; align-items: center; justify-content: center; color: var(--color-text-faint); font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em; }
    .act-badge { position: absolute; top: var(--space-3); left: var(--space-3); background: var(--color-gold); color: #0d0b1a; font-family: var(--font-display); font-size: 0.75rem; font-weight: 700; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .act-badge-wide { position: absolute; top: var(--space-3); left: var(--space-3); background: var(--color-gold); color: #0d0b1a; font-family: var(--font-display); font-size: 0.65rem; font-weight: 700; padding: 0 0.5rem; height: 28px; border-radius: 14px; display: flex; align-items: center; justify-content: center; white-space: nowrap; }
    .act-body { padding: var(--space-4); }
    .act-title { font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.05em; color: var(--color-text); margin-bottom: var(--space-2); }
    .act-description { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: var(--space-4); }
    .act-footer { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-2); }
    .act-status { display: inline-block; font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.1em; font-weight: 600; padding: 0.25rem 0.75rem; border-width: 1px; border-style: solid; }
    .act-status.complete { background: rgba(80,180,100,0.1); border-color: rgba(80,180,100,0.4); color: #6ecf85; }
    .act-status.in-progress { background: rgba(201,168,76,0.1); border-color: rgba(201,168,76,0.4); color: var(--color-gold); }
    .act-status.upcoming { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.1); color: var(--color-text-faint); }
    .act-watch { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.1em; color: var(--color-gold); text-transform: uppercase; transition: color 0.2s; }
    .act-watch:hover { color: var(--color-gold-hover); }
    .act-episodes { margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 0.3rem; }
    .act-episode-link { font-size: 0.72rem; color: var(--color-text-muted); transition: color 0.2s; display: inline-flex; align-items: center; gap: 0.35rem; }
    .act-episode-link:hover { color: var(--color-gold); }
    .view-all-link { display: flex; align-items: center; justify-content: center; gap: var(--space-2); margin-top: var(--space-8); font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0.12em; color: var(--color-gold); text-transform: uppercase; transition: color 0.2s; }
    .view-all-link:hover { color: var(--color-gold-hover); }

    /* ===== IMAGE GALLERY BANNER ===== */
    .gallery-banner { position: relative; z-index: 1; padding: var(--space-12) var(--space-8); }
    .gallery-banner-inner { max-width: 1100px; margin: 0 auto; background: var(--color-surface); border: 1px solid var(--color-border); padding: var(--space-8) var(--space-12); display: flex; align-items: center; justify-content: space-between; gap: var(--space-8); flex-wrap: wrap; }
    .gallery-banner-title { font-family: var(--font-display); font-size: clamp(0.9rem, 1.8vw, 1.1rem); font-weight: 700; letter-spacing: 0.12em; color: var(--color-text); text-transform: uppercase; margin-bottom: var(--space-2); }
    .gallery-banner-sub { font-size: 0.82rem; color: var(--color-text-muted); }
    .gallery-icon { font-size: 2rem; color: var(--color-gold); flex-shrink: 0; }

    /* ===== BEHIND THE CRAFT ===== */
    .behind-craft {
      position: relative; z-index: 1;
      padding: var(--space-20) var(--space-8);
    }
    .behind-craft-inner { max-width: 1100px; margin: 0 auto; }
    .behind-craft-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      margin-top: var(--space-12);
    }
    .craft-log {
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: var(--space-8);
      display: flex; flex-direction: column; gap: var(--space-4);
    }
    .craft-log-phase {
      font-family: var(--font-display); font-size: 0.65rem;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--color-gold); margin-bottom: var(--space-2);
    }
    .craft-log-title {
      font-family: var(--font-display); font-size: 0.95rem;
      font-weight: 700; letter-spacing: 0.06em; color: var(--color-text);
      margin-bottom: var(--space-3);
    }
    .craft-log-body {
      font-size: 0.83rem; color: var(--color-text-muted);
      line-height: 1.8; flex: 1;
    }
    .craft-log-links {
      display: flex; flex-direction: column; gap: 0.4rem;
      margin-top: var(--space-4);
      padding-top: var(--space-4);
      border-top: 1px solid var(--color-border);
    }
    .craft-log-link {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: var(--font-display); font-size: 0.68rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--color-gold); transition: color 0.2s;
    }
    .craft-log-link:hover { color: var(--color-gold-hover); }
    .craft-log-link.tiktok { color: var(--color-text-muted); }
    .craft-log-link.tiktok:hover { color: var(--color-gold); }

    /* Tools table */
    .tools-section {
      margin-top: var(--space-12);
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      padding: var(--space-8);
    }
    .tools-section-title {
      font-family: var(--font-display); font-size: 0.8rem;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--color-gold); margin-bottom: var(--space-6);
    }
    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: var(--space-4);
    }
    .tool-item {
      display: flex; gap: var(--space-3);
      align-items: flex-start;
    }
    .tool-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--color-gold); flex-shrink: 0;
      margin-top: 0.45rem;
    }
    .tool-name {
      font-family: var(--font-display); font-size: 0.72rem;
      font-weight: 700; letter-spacing: 0.08em;
      color: var(--color-text); display: block; margin-bottom: 0.2rem;
    }
    .tool-desc {
      font-size: 0.76rem; color: var(--color-text-muted); line-height: 1.6;
    }

    /* ===== CHARACTERS ===== */
    .characters { position: relative; z-index: 1; padding: var(--space-20) var(--space-8); }
    .characters-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: var(--space-6); max-width: 1100px; margin: 0 auto; }
    .character-card { background: var(--color-surface); border: 1px solid var(--color-border); padding: var(--space-4); text-align: left; transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s; }
    .character-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(201,168,76,0.12); border-color: rgba(201,168,76,0.3); }
    .character-portrait { width: 100%; aspect-ratio: 1/1; overflow: hidden; margin-bottom: var(--space-4); background: var(--color-surface-2); }
    .character-portrait img { width: 100%; height: 100%; object-fit: cover; }
    .portrait-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #221d40, #13102b); display: flex; align-items: center; justify-content: center; color: var(--color-text-faint); font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em; }
    .character-name { font-family: var(--font-display); font-size: 1rem; font-weight: 700; color: var(--color-text); letter-spacing: 0.08em; margin-bottom: var(--space-2); }
    .character-bio { font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; margin-bottom: var(--space-4); }
    .character-link { font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--color-gold); text-transform: uppercase; transition: color 0.2s; display: inline-flex; align-items: center; gap: var(--space-2); }
    .character-link:hover { color: var(--color-gold-hover); }

    /* ===== THE CRAFT ===== */
    .craft { position: relative; z-index: 1; padding: var(--space-20) var(--space-8); background: linear-gradient(to bottom, transparent, rgba(19,16,43,0.5) 20%, rgba(19,16,43,0.5) 80%, transparent); }
    .craft-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-6); max-width: 1100px; margin: 0 auto; }
    .craft-card { background: var(--color-surface); border: 1px solid var(--color-border); padding: var(--space-8); display: flex; flex-direction: column; gap: var(--space-4); }
    .craft-icon { width: 40px; height: 40px; color: var(--color-gold); }
    .craft-title { font-family: var(--font-display); font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; color: var(--color-text); text-transform: uppercase; }
    .craft-desc { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.7; }

    /* ===== THE WORLD ===== */
    .world { position: relative; z-index: 1; min-height: 500px; display: flex; align-items: center; overflow: hidden; }
    .world-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0d0b1a 0%, #1a1535 50%, #0d0b1a 100%); }
    .world-bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.4; }
    .world-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(13,11,26,0.95) 40%, rgba(13,11,26,0.4) 100%); }
    .world-content { position: relative; z-index: 2; padding: var(--space-20) var(--space-8); max-width: 560px; }
    .world-heading { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; color: var(--color-gold); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-4); }
    .world-body { font-size: 0.95rem; color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--space-8); }

    /* ===== NEWSLETTER ===== */
    .newsletter { position: relative; z-index: 1; padding: var(--space-16) var(--space-8); background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
    .newsletter-inner { max-width: 900px; margin: 0 auto; display: flex; align-items: center; gap: var(--space-12); flex-wrap: wrap; }
    .newsletter-icon { font-size: 2.5rem; color: var(--color-gold); flex-shrink: 0; }
    .newsletter-text { flex: 1; min-width: 260px; }
    .newsletter-heading { font-family: var(--font-display); font-size: clamp(1rem, 2vw, 1.4rem); font-weight: 700; letter-spacing: 0.1em; color: var(--color-text); text-transform: uppercase; margin-bottom: var(--space-2); }
    .newsletter-sub { font-size: 0.875rem; color: var(--color-text-muted); }
    .newsletter-form { flex: 1; min-width: 260px; }
    .newsletter-input-row { display: flex; gap: 0; border: 1px solid var(--color-border); }
    .newsletter-input { flex: 1; background: var(--color-bg); border: none; outline: none; padding: 0.75rem var(--space-4); color: var(--color-text); font-family: var(--font-body); font-size: 0.875rem; }
    .newsletter-input::placeholder { color: var(--color-text-faint); }
    .newsletter-btn { background: var(--color-gold); color: #0d0b1a; font-family: var(--font-display); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; border: none; padding: 0.75rem var(--space-4); cursor: pointer; white-space: nowrap; transition: background 0.2s; min-height: 44px; }
    .newsletter-btn:hover { background: var(--color-gold-hover); }
    .newsletter-note { font-size: 0.75rem; color: var(--color-text-faint); margin-top: var(--space-2); text-align: center; }
    .newsletter-success { display: none; color: var(--color-gold); font-family: var(--font-display); font-size: 0.8rem; letter-spacing: 0.05em; margin-top: var(--space-2); }

    /* ===== FOOTER ===== */
    .footer { position: relative; z-index: 1; padding: var(--space-16) var(--space-8) var(--space-8); background: var(--color-bg); }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: var(--space-8); max-width: 1100px; margin: 0 auto; padding-bottom: var(--space-8); border-bottom: 1px solid var(--color-border); }
    .footer-logo { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--color-gold); letter-spacing: 0.1em; margin-bottom: var(--space-2); }
    .footer-logo-sub { font-family: var(--font-display); font-size: 0.65rem; letter-spacing: 0.15em; color: var(--color-text-faint); text-transform: uppercase; margin-bottom: var(--space-4); }
    .footer-tagline { font-style: italic; font-size: 0.8rem; color: var(--color-text-muted); line-height: 1.6; }
    .footer-col-title { font-family: var(--font-display); font-size: 0.7rem; letter-spacing: 0.15em; color: var(--color-gold); text-transform: uppercase; margin-bottom: var(--space-4); }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-3); }
    .footer-col a { font-size: 0.82rem; color: var(--color-text-muted); transition: color 0.2s; }
    .footer-col a:hover { color: var(--color-gold); }
    .social-icons { display: flex; gap: var(--space-4); flex-wrap: wrap; }
